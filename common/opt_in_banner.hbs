{{! MRF Opt-in Banner — Phase 1 theme switcher }}
{{#if showOptInBanner}}
<div class="mrf-opt-in-banner" id="mrfOptInBanner">
  <div class="mrf-opt-in-content">
    <div class="mrf-opt-in-message">
      <h3>{{i18n "mrf.optin.headline" default="The new Mineral Rights Forum is here"}}</h3>
      <p>{{i18n "mrf.optin.subtitle" default="Try the redesigned forum with our fresh navy and gold look"}}</p>
    </div>

    <div class="mrf-opt-in-actions">
      <button class="btn btn-primary mrf-try-now" data-action="enable-new-theme">
        {{i18n "mrf.optin.try_now" default="Try it now"}}
      </button>
      <button class="btn btn-default mrf-dismiss" data-action="dismiss-banner">
        {{i18n "mrf.optin.dismiss" default="Later"}}
      </button>
    </div>
  </div>

  <button class="mrf-close-banner" aria-label="Close" data-action="dismiss-banner">
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M15 5L5 15M5 5l10 10"></path>
    </svg>
  </button>
</div>
{{/if}}


<script>
  (function() {
    const BANNER_DISMISSED_KEY = 'mrf-banner-dismissed';
    const THEME_PREFERENCE_KEY = 'mrf-theme-preference';

    // Helper: Get current theme ID
    function getCurrentThemeId() {
      // In Discourse, this would be dynamically set by the theme system
      return document.body.dataset.currentThemeId || 1;
    }

    // Helper: Get new theme ID
    function getNewThemeId() {
      // This would be the ID of the new "MRF Navy & Gold" theme
      // In production, this should be injected from Discourse admin settings
      return document.body.dataset.newThemeId || 2;
    }

    // Initialize banner visibility
    function initBanner() {
      const dismissed = localStorage.getItem(BANNER_DISMISSED_KEY);
      if (!dismissed) {
        // Show banner on page load
        const banner = document.getElementById('mrfOptInBanner');
        if (banner) {
          banner.style.display = 'block';
        }
      }
    }

    // Handle "Try it now" click
    document.addEventListener('click', function(e) {
      if (e.target.closest('[data-action="enable-new-theme"]')) {
        e.preventDefault();
        enableNewTheme();
      }
    });

    // Handle "Later" / close click
    document.addEventListener('click', function(e) {
      if (e.target.closest('[data-action="dismiss-banner"]') ||
          e.target.closest('.mrf-close-banner')) {
        e.preventDefault();
        dismissBanner();
      }
    });

    function enableNewTheme() {
      const newThemeId = getNewThemeId();

      // For logged-in users: change theme preference via Discourse API
      if (window.Discourse && window.Discourse.User) {
        fetch(`/user-api-key/new`, {
          method: 'POST',
          headers: { 'X-CSRF-Token': getCsrfToken() },
          body: JSON.stringify({
            application_name: 'MRF Theme Switcher',
            scopes: ['read', 'write']
          })
        }).then(() => {
          // Reload with new theme
          window.location.href = `/?preview_theme_id=${newThemeId}`;
        });
      } else {
        // For logged-out users: use localStorage + preview_theme_id
        localStorage.setItem(THEME_PREFERENCE_KEY, newThemeId);
        window.location.href = `/?preview_theme_id=${newThemeId}`;
      }
    }

    function dismissBanner() {
      localStorage.setItem(BANNER_DISMISSED_KEY, 'true');
      const banner = document.getElementById('mrfOptInBanner');
      if (banner) {
        banner.style.animation = 'slideUp 0.3s ease-out forwards';
        setTimeout(() => {
          banner.remove();
        }, 300);
      }
    }

    // Helper: Get CSRF token
    function getCsrfToken() {
      const meta = document.querySelector('meta[name="csrf-token"]');
      return meta ? meta.getAttribute('content') : '';
    }

    // Initialize on page load
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initBanner);
    } else {
      initBanner();
    }

    // Listen for manual theme toggle events (from footer)
    document.addEventListener('mrf:toggleTheme', function() {
      const pref = localStorage.getItem(THEME_PREFERENCE_KEY);
      const currentTheme = getCurrentThemeId();
      const newTheme = getNewThemeId();
      const targetTheme = pref === String(newTheme) ? currentTheme : newTheme;

      localStorage.setItem(THEME_PREFERENCE_KEY, targetTheme);
      window.location.href = `/?preview_theme_id=${targetTheme}`;
    });
  })();

  @keyframes slideUp {
    to {
      opacity: 0;
      transform: translateY(-20px);
    }
  }
</script>
